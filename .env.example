# ===============================
# ISTBAKU production env vars
# Kopyala: cp .env.example .env.local
# ===============================

NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Postgres (Neon önerilir) ----
# Neon: https://console.neon.tech → Project → Connection string
# Lokalde de aynı URL kullanılabilir; ya da: postgres://user:pass@localhost:5432/istbaku
DATABASE_URL=postgres://user:password@host:5432/istbaku?sslmode=require

# ---- iron-session (cookie şifreleme anahtarı) ----
# En az 32 karakter olmalı. Üretmek için: openssl rand -base64 32
SESSION_PASSWORD=replace-this-with-a-long-random-string-at-least-32-chars

# ---- Vercel Blob (foto/video storage) ----
# Vercel Dashboard → Storage → Blob → Create → Token
# Yoksa fallback: public/uploads dizinine yazar (sadece dev için)
BLOB_READ_WRITE_TOKEN=

# ---- AI mock latency (ms) ----
MOCK_AI_LATENCY_MS=600
